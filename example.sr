
const create_adder: (int32) -> (int32) -> int32 = (x: int32): (int32) -> int32 -> {
    return (y: int32): int32 -> {
        return x + y;
    };
};

fn main(): int32 {
    const add_five: (int32) -> int32 = create_adder(5);
    const result: int32 = add_five(10);

    printf("%d\n", result); // This will print 15

    return 0;
}