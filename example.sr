import System::{
io::print
};

type Array<T> = T[];

type Car = {
    drive: () -> void;
    names: Array<string>;
};

fn makeCar(): Car {
    const names = ["Toyota", "Honda", "Ford"];
    return Car::{ drive: (): void -> {
        io::print("Driving: %s, %s, %s", names[0], names[1], names[2]);
    }, names, };
}

fn main(): i32 {

    const myCar = makeCar();
    myCar.drive();

    return 0;
}