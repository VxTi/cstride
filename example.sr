import system::{ io::print };

const create_adder = (x: int32): (int32) -> int32 -> {
    return (y: int32): int32 -> {
        return x + y;
    };
};

fn main(): int32 {
    const add_five = create_adder(5);
    const result: int32 = add_five(10);

    io::print("Result: %d. Type something else: ", result); // Should print "Result: 15"

    const input = io::read(10);

    io::print("You entered: %s", input);
    return 0;
}