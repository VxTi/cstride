package System;

pub type Array<T> = {
    length: i32;
    data: T [];
};

pub type MapEntry<K, V> = {
    key: K;
    value: V;
};

pub type Map<K, V> = {
    entries: MapEntry<K, V>[];
};

pub fn arrayOf<T>(members: T[]): Array<T> {
    return Array<T>::{ length: members.length, data: members };
}
