const lambdas: ((int32) -> int32)[] = [
    (x: int32): int32 -> { return x + 1; },
    (x: int32): int32 -> { return x * 2; },
    (x: int32): int32 -> { return x - 1; }
];

extern fn printf(format: string, ...): void;

fn main(): void {
    const first: (int32) -> int32 = lambdas[0];
    const result: int32 = first(10);

    printf("Result: %d\n", result);
}